                      <div className="text-right">
                        <div className="text-sm font-bold text-white">-450.00</div>
                        <div className="text-[10px] text-slate-400">USD-B</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            )}
            
            {/* OFFLINE BEARER NOTE MODAL */}
            {showBearerNote && (
              <div className="fixed inset-0 z-[100] flex items-center justify-center px-4">
                <div className="absolute inset-0 bg-black/80 backdrop-blur-md" onClick={() => setShowBearerNote(false)}></div>
                <div className="skeuo-leather w-full max-w-sm p-6 relative z-10 animate-in zoom-in-95 shadow-2xl">
                  <div className="skeuo-stitch"></div>
                  
                  <div className="relative z-20 text-center">
                    <div className="inline-flex items-center justify-center w-12 h-12 skeuo-metal rounded-full mb-4">
                      <Nfc size={24}/>
                    </div>
                    <h3 className="text-xl font-bold text-amber-500 mb-1 text-shadow-sm">Bearer Note Signed</h3>
                    <p className="text-xs text-amber-200/70 mb-6 font-mono">TTL: 04:59 | Max Spend: 500 USD-B</p>
                    
                    <div className="bg-white p-4 rounded-xl mx-auto w-48 h-48 flex items-center justify-center mb-6 shadow-[inset_0_2px_10px_rgba(0,0,0,0.2)]">
                      <QrCode size={160} className="text-slate-900"/>
                    </div>
                    
                    <div className="e-ink-display p-3 mb-6 text-left">
