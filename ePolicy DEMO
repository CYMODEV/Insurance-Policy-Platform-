                  <p className="text-xs text-slate-400 mb-6">Convert Fiat to USD-B Stable Notes</p>
                  
                  <form onSubmit={(e) => {
                    e.preventDefault(); setIsProcessing(true);
                    setTimeout(() => {
                      setBalances(prev => ({ ...prev, usdB: prev.usdB + Number(fiatAmount) }));
                      setIsProcessing(false); setShowFiatRamp(false);
                      showToast(`Funded ePurse with ${fiatAmount} USD-B.`);
