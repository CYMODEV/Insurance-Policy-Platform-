            <button onClick={() => setActiveTab('capital')} disabled={!hasPolicy} className={`flex flex-1 flex-col items-center p-2 rounded-2xl transition-all duration-300 ${activeTab === 'capital' ? 'text-white glass-panel bg-white/10 shadow-[0_0_15px_rgba(255,255,255,0.05)]' : 'text-slate-500 hover:text-slate-300'} ${!hasPolicy && 'opacity-30 cursor-not-allowed'}`}>
              <Landmark size={20} className="mb-1" />
              <span className="text-[9px] font-bold tracking-wide">Capital</span>
            </button>

            <button onClick={() => setActiveTab('cpurse')} disabled={!hasPolicy} className={`flex flex-1 flex-col items-center p-2 rounded-2xl transition-all duration-300 ${activeTab === 'cpurse' ? 'text-white glass-panel bg-white/10 shadow-[0_0_15px_rgba(255,255,255,0.05)]' : 'text-slate-500 hover:text-slate-300'} ${!hasPolicy && 'opacity-30 cursor-not-allowed'}`}>
              <Banknote size={20} className="mb-1" />
              <span className="text-[9px] font-bold tracking-wide">cPurse</span>
            </button>
            
            <button onClick={() => setActiveTab('steward')} disabled={!hasPolicy} className={`flex flex-1 flex-col items-center p-2 rounded-2xl transition-all duration-300 ${activeTab === 'steward' ? 'text-white glass-panel bg-white/10 shadow-[0_0_15px_rgba(255,255,255,0.05)]' : 'text-slate-500 hover:text-slate-300'} ${!hasPolicy && 'opacity-30 cursor-not-allowed'} relative`}>
