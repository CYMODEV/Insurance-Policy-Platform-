            {/* FIAT ON-RAMP MODAL */}
            {showFiatRamp && (
              <div className="fixed inset-0 z-[100] flex items-end justify-center sm:items-center px-4 pb-20 sm:p-0">
                <div className="absolute inset-0 bg-black/60 backdrop-blur-sm" onClick={() => setShowFiatRamp(false)}></div>
