                  <div className="space-y-3">
                    <div className="flex justify-between items-center glass-panel bg-white/5 p-3 rounded-xl border-white/5 opacity-70">
                      <div className="flex items-center gap-3">
                        <div className="w-8 h-8 rounded-full bg-rose-500/20 text-rose-400 flex items-center justify-center"><Banknote size={14}/></div>
