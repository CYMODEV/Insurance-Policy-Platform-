                      <div className="text-[9px] break-all opacity-80">
                        0x8f3a9b...[AIRGAPPED_SIG]...2c4e1
                      </div>
                    </div>

                    <button 
                      onClick={() => setShowBearerNote(false)}
                      className="w-full skeuo-metal py-3 rounded-lg font-bold text-sm active:translate-y-1"
