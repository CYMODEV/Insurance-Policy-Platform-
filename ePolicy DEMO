// Helper component for message boxes
const ToastMessage = ({ message, onClose }) => {
  if (!message) return null;
  return (
    <div className="fixed top-24 left-1/2 -translate-x-1/2 z-[200] w-11/12 max-w-sm">
      <div className="glass-panel-highlight bg-indigo-900/90 border border-indigo-400/50 p-4 rounded-xl flex items-start gap-3 shadow-2xl animate-in slide-in-from-top-4">
        <AlertTriangle className="text-amber-400 shrink-0 mt-0.5" size={20} />
        <p className="text-sm font-medium text-white flex-1">{message}</p>
        <button onClick={onClose} className="text-white/50 hover:text-white transition-colors">
          <X size={18} />
        </button>
      </div>
    </div>
  );
};

