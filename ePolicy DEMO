            <button onClick={() => isKycVerified ? hasPolicy ? setActiveTab('dashboard') : setActiveTab('mint') : setActiveTab('onboarding')} className={`flex flex-1 flex-col items-center p-2 rounded-2xl transition-all duration-300 ${activeTab === 'dashboard' || activeTab === 'onboarding' || activeTab === 'mint' ? 'text-white glass-panel bg-white/10 shadow-[0_0_15px_rgba(255,255,255,0.05)]' : 'text-slate-500 hover:text-slate-300'}`}>
