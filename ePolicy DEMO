      <div className="fixed bottom-0 w-full z-50 pb-safe">
        <div className="glass-panel bg-[#0f111a]/60 border-b-0 border-x-0 border-t border-white/10 rounded-t-3xl shadow-[0_-10px_40px_rgba(0,0,0,0.3)]">
