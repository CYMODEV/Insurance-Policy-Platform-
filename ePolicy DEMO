                      </div>
                    </div>
                    <button type="submit" disabled={isProcessing} className="w-full skeuo-btn text-white font-bold py-4 mt-4 flex items-center justify-center gap-2">
                      {isProcessing ? <><Loader2 size={18} className="animate-spin text-indigo-300" /> Processing...</> : <><CreditCard size={18} /> Pay {fiatAmount} USD</>}
                    </button>
                    <button type="button" onClick={() => setShowFiatRamp(false)} className="w-full text-slate-400 hover:text-white text-sm py-2">Cancel</button>
