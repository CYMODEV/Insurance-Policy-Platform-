                    <div className="e-ink-display p-3 mb-4">
                      <div className="text-[10px] uppercase tracking-widest text-slate-500 mb-1 font-sans font-bold">Available Offline Spend</div>
                      <div className="text-2xl font-bold">{balances.usdB.toLocaleString('en-US', { minimumFractionDigits: 2 })} <span className="text-sm">USD-B</span></div>
                    </div>

                    <div className="flex justify-between items-end">
                      <div className="font-mono text-slate-400 text-xs">
                        ID: 0x8F...A1B2
                      </div>
                      <div className="text-slate-500">
                        <DynamicLogo className="scale-75 origin-bottom-right opacity-50 grayscale"/>
                      </div>
                    </div>
                  </div>

                  {/* Actions Panel */}
                  <div className="relative z-20 space-y-3">
                    <button 
                      onClick={() => setOfflineMode(!offlineMode)}
                      className={`w-full skeuo-metal py-3 rounded-lg font-bold text-sm flex items-center justify-center gap-2 transition-all active:translate-y-1 ${offlineMode ? 'shadow-[inset_0_3px_6px_rgba(0,0,0,0.4)] bg-gradient-to-t' : ''}`}
                    >
                      {offlineMode ? <Network size={18}/> : <WifiOff size={18}/>}
                      {offlineMode ? 'Reconnect to Ledger' : 'Sever Connection (Air-Gap)'}
                    </button>
                    
                    <button 
                      onClick={() => setShowBearerNote(true)}
                      disabled={!offlineMode}
                      className="w-full bg-gradient-to-b from-amber-600 to-amber-800 border border-amber-900 shadow-[inset_0_1px_0_rgba(255,255,255,0.3),0_4px_6px_rgba(0,0,0,0.5)] text-white py-3 rounded-lg font-bold text-sm flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed active:translate-y-1 transition-all text-shadow-sm"
