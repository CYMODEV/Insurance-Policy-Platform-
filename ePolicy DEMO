              <Scale size={20} className="mb-1" />
              <span className="text-[9px] font-bold tracking-wide">Steward</span>
            </button>

            <button onClick={() => setActiveTab('data')} disabled={!hasPolicy} className={`flex flex-1 flex-col items-center p-2 rounded-2xl transition-all duration-300 ${activeTab === 'data' ? 'text-white glass-panel bg-white/10 shadow-[0_0_15px_rgba(255,255,255,0.05)]' : 'text-slate-500 hover:text-slate-300'} ${!hasPolicy && 'opacity-30 cursor-not-allowed'}`}>
