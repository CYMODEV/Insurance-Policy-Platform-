                        { type: 'Rx', name: 'PillPack Smart Dispenser', desc: 'ScriptID: RX-772... • Pharmacy Node', icon: Pill, color: 'text-teal-300', bg: 'bg-teal-500/10' },
                        { type: 'Dental', name: 'Oral-B iO Series 10', desc: 'MAC: 88:1B... • Dental Telemetry', icon: Smile, color: 'text-pink-300', bg: 'bg-pink-500/10' },
                        { type: 'Employment', name: 'ADP Payroll Oracle', desc: 'API: ADP-882... • Income Sync', icon: Briefcase, color: 'text-emerald-300', bg: 'bg-emerald-500/10' }
                      ].map((node, idx) => (
                        <div key={idx} className="glass-panel bg-white/[0.02] border-white/5 rounded-xl p-3 flex justify-between items-center group hover:bg-white/[0.05] transition-colors cursor-pointer">
                          <div className="flex items-center gap-3">
                            <div className={`w-10 h-10 rounded-full glass-panel flex items-center justify-center ${node.bg}`}>
                              <node.icon size={16} className={node.color} />
                            </div>
                            <div>
                              <div className="text-sm font-bold text-slate-200 group-hover:text-white transition-colors">{node.name}</div>
                              <div className="text-[10px] font-mono text-slate-500 mt-0.5">{node.desc}</div>
                            </div>
                          </div>
                          <div className="flex flex-col items-end gap-1">
                            <CheckCircle size={14} className="text-emerald-500" />
                            <span className="text-[8px] uppercase tracking-widest text-emerald-400/70 font-bold">Synced</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {registryView === 'agents' && (
                  <div className="glass-panel rounded-3xl p-7 relative overflow-hidden animate-in fade-in duration-300">
                    <div className="absolute top-0 right-0 w-40 h-40 bg-yellow-500/10 blur-3xl rounded-full"></div>
                    <div className="relative z-10 mb-6">
                      <h2 className="text-2xl font-bold text-white mb-2">Verified Agent Brokers</h2>
                      <p className="text-sm text-slate-400">Discover and connect with licensed decentralized insurance agents participating in the ePolicy DAO.</p>
                    </div>
                    <div className="space-y-4 relative z-10">
                      {[
                        { did: 'BrokerNode_0x4A9', rating: 99.8, clients: 142, licenses: 'CA, NY, FL', specialized: 'Mobility, Cyber' },
                        { did: 'DAO_Underwriters_LLC', rating: 98.5, clients: 890, licenses: 'Global', specialized: 'Commercial, Property' },
                        { did: 'CryptoRisk_Advisors', rating: 96.2, clients: 34, licenses: 'TX, NV', specialized: 'Health, Pet' }
                      ].map((agent, i) => (
                        <div key={i} className="glass-panel p-5 rounded-2xl border border-white/5 flex flex-col md:flex-row md:items-center justify-between gap-4">
                          <div className="flex items-center gap-4">
                            <div className="w-12 h-12 rounded-full glass-panel bg-yellow-500/10 text-yellow-400 flex items-center justify-center border border-yellow-500/20">
                              <Briefcase size={20}/>
                            </div>
                            <div>
                              <div className="font-mono text-sm font-bold text-slate-200">{agent.did}</div>
                              <div className="text-[10px] text-slate-400 mt-1">Specialties: <span className="text-slate-300">{agent.specialized}</span></div>
                            </div>
                          </div>
                          <div className="grid grid-cols-3 gap-4 text-center md:text-right">
                            <div>
                              <div className="text-lg font-mono font-bold text-emerald-400">{agent.rating}</div>
                              <div className="text-[9px] uppercase tracking-widest text-slate-500">DAO Rating</div>
                            </div>
                            <div>
                              <div className="text-lg font-mono font-bold text-white">{agent.clients}</div>
                              <div className="text-[9px] uppercase tracking-widest text-slate-500">Clients</div>
                            </div>
                            <div>
                              <div className="text-sm font-bold text-slate-300 mt-1">{agent.licenses}</div>
                              <div className="text-[9px] uppercase tracking-widest text-slate-500">Licensed</div>
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {registryView === 'partners' && (
                  <div className="glass-panel rounded-3xl p-7 relative overflow-hidden animate-in fade-in duration-300">
                    <div className="absolute top-0 right-0 w-40 h-40 bg-emerald-500/10 blur-3xl rounded-full"></div>
                    <div className="relative z-10 mb-6">
                      <h2 className="text-2xl font-bold text-white mb-2">Oracle Data Partners</h2>
                      <p className="text-sm text-slate-400">The verified network of hardware and software API providers acting as truth oracles for parametric claims.</p>
                    </div>
                    <div className="grid gap-4 md:grid-cols-2 relative z-10">
                      {[
                        { name: 'Tesla Telematics Auth', category: 'Mobility', uptime: '99.99%', status: 'Active', icon: Car },
                        { name: 'Apple HealthKit ZK-Relay', category: 'Bio-Metric', uptime: '100%', status: 'Active', icon: HeartPulse },
                        { name: 'ADP Payroll API Node', category: 'Employment', uptime: '99.95%', status: 'Active', icon: Briefcase },
                        { name: 'Chainalysis AML Oracle', category: 'Cyber', uptime: '100%', status: 'Active', icon: ShieldCheck }
                      ].map((partner, i) => (
                        <div key={i} className="glass-panel p-4 rounded-xl border border-white/5 flex justify-between items-center">
                          <div className="flex items-center gap-3">
                            <div className="w-10 h-10 rounded-full glass-panel bg-white/5 text-slate-300 flex items-center justify-center">
                              <partner.icon size={16}/>
                            </div>
                            <div>
                              <div className="text-sm font-bold text-white">{partner.name}</div>
                              <div className="text-[10px] text-slate-400 uppercase tracking-widest mt-0.5">{partner.category} Provider</div>
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            )}

            {/* VIEW: MINT OMNI-POLICY */}
            {activeTab === 'mint' && (
              <div className="space-y-6 animate-in fade-in duration-500">
                <div className="flex justify-between items-center bg-[#0a0c10]/50 p-3 rounded-2xl border border-white/5 mb-2">
                  <div className="flex gap-2 items-center">
                    <button 
                      onClick={() => {
                        if (policyStep === 'compliance') setPolicyStep('config');
                        else if (policyStep === 'config') setPolicyStep('type');
                        else {
                          if (hasPolicy) setActiveTab('dashboard');
                          else setActiveTab('onboarding');
                        }
                      }}
                      className="text-slate-400 hover:text-white transition-colors flex items-center gap-1 text-xs font-bold"
                    >
                      <ArrowLeft size={14}/> Back
                    </button>
                  </div>
                  <div className="flex items-center gap-1.5 text-[10px] uppercase tracking-widest font-bold text-slate-500">
                    <span className={policyStep === 'type' ? 'text-blue-400' : 'text-slate-600'}>Class</span>
                    <ChevronRight size={10} />
                    <span className={policyStep === 'config' ? 'text-blue-400' : 'text-slate-600'}>Params</span>
                    <ChevronRight size={10} />
                    <span className={policyStep === 'compliance' ? 'text-blue-400' : 'text-slate-600'}>App</span>
                    <ChevronRight size={10} />
                    <span className={policyStep === 'ready' ? 'text-emerald-400' : 'text-slate-600'}>Bound</span>
                  </div>
                </div>

                <div className="glass-panel rounded-3xl p-7 relative overflow-hidden">
                  <div className="absolute top-0 right-0 w-40 h-40 bg-blue-500/10 blur-3xl rounded-full"></div>
                  
                  {policyStep === 'type' && (
                    <div className="animate-in fade-in duration-300 relative z-10">
                      <h2 className="text-2xl font-bold mb-2 text-white">Select Policy Class</h2>
                      <div className={`grid gap-4 ${isMobileView ? 'grid-cols-2' : 'grid-cols-3 md:grid-cols-5'}`}>
                        {Object.entries(assetMeta).map(([typeId, meta]) => (
                          <div key={typeId} onClick={() => { setSelectedAssetType(typeId); setPolicyStep('config'); }} className="glass-panel bg-white/5 hover:bg-white/10 border-white/10 p-5 rounded-2xl cursor-pointer transition-all flex flex-col items-center text-center group">
                            <meta.icon size={32} className="text-blue-400 mb-3 group-hover:scale-110 transition-transform" />
                            <div className="font-bold text-white text-sm">{meta.label}</div>
                            <div className="text-[10px] text-slate-400 mt-1">{meta.sub}</div>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {policyStep === 'config' && (
                    <div className="animate-in fade-in duration-300 relative z-10 space-y-6">
                      <div className="flex items-center gap-3">
                        <div className="w-10 h-10 rounded-full glass-panel bg-blue-500/20 flex items-center justify-center text-blue-300">
                          {React.createElement(assetMeta[selectedAssetType].icon, { size: 20 })}
                        </div>
                        <h2 className="text-xl font-bold text-white">Configure Parameters</h2>
                      </div>
                      
                      <div className="grid grid-cols-2 gap-3">
                        <div>
                          <label className="block text-xs font-medium text-slate-400 mb-1.5 ml-1">Limit Tier</label>
                          <select className="w-full glass-input rounded-xl px-3 py-3 text-slate-200 text-sm" value={policyConfig.tier} onChange={(e) => setPolicyConfig({...policyConfig, tier: e.target.value})}>
                            <option value="standard">Standard Limit</option>
                            <option value="premium">Premium Limit</option>
                          </select>
                        </div>
                        <div>
                          <label className="block text-xs font-medium text-slate-400 mb-1.5 ml-1">Deductible</label>
                          <select className="w-full glass-input rounded-xl px-3 py-3 text-slate-200 text-sm" value={policyConfig.deductible} onChange={(e) => setPolicyConfig({...policyConfig, deductible: Number(e.target.value)})}>
                            <option value={1000}>1,000 USD-B</option>
                            <option value={500}>500 USD-B</option>
                            <option value={250}>250 USD-B</option>
                          </select>
                        </div>
                      </div>

                      <div className="glass-panel-highlight rounded-2xl p-4 mt-6 flex justify-between items-center border border-blue-500/30">
                        <div>
                          <div className="text-xs text-blue-200/70 font-bold uppercase mb-1">Live Estimate</div>
                          <div className="text-2xl font-mono font-bold text-white">{getEstimatedPremium()} <span className="text-sm font-sans text-blue-300">USD-B/mo</span></div>
                        </div>
                        <button onClick={() => setPolicyStep('compliance')} className="sleek-btn text-white font-bold py-3 px-6 rounded-xl flex items-center gap-2 text-sm">
                          Next <ArrowRightLeft size={16} />
                        </button>
                      </div>
                    </div>
                  )}

                  {policyStep === 'compliance' && (
                    <div className="animate-in slide-in-from-right duration-300 relative z-10 space-y-6">
                      <h2 className="text-xl font-bold text-white">Application Verification</h2>
                      <div className="space-y-4">
                        <input type="text" placeholder={assetMeta[selectedAssetType].appFields[0]} className="w-full glass-input rounded-xl px-4 py-3 text-sm" value={appData.field1} onChange={e => setAppData({...appData, field1: e.target.value})} />
                        <input type="text" placeholder={assetMeta[selectedAssetType].appFields[1]} className="w-full glass-input rounded-xl px-4 py-3 text-sm" value={appData.field2} onChange={e => setAppData({...appData, field2: e.target.value})} />
                        
                        <button onClick={handleVerifyApplication} className="w-full glass-panel bg-blue-500/20 text-blue-200 font-semibold py-3 rounded-xl text-sm">
                          {isVerifyingData ? 'Querying Oracles...' : 'Verify Data'}
                        </button>

                        <label className="flex items-start gap-3 cursor-pointer group">
                          <input type="checkbox" className="mt-1" checked={complianceChecked.reg1} onChange={(e) => setComplianceChecked({...complianceChecked, reg1: e.target.checked})} />
                          <span className="text-xs text-slate-300 leading-tight">I cryptographically consent to all regulatory terms.</span>
                        </label>
                        <label className="flex items-start gap-3 cursor-pointer group">
                          <input type="checkbox" className="mt-1" checked={complianceChecked.reg2} onChange={(e) => setComplianceChecked({...complianceChecked, reg2: e.target.checked})} />
                          <span className="text-xs text-slate-300 leading-tight">I acknowledge the automated smart contract execution.</span>
                        </label>
                      </div>

                      <button onClick={handleGeneratePolicy} disabled={!complianceChecked.reg1 || !complianceChecked.reg2 || !isDataVerified} className="w-full sleek-btn text-white font-bold py-4 rounded-xl text-sm disabled:opacity-50">
                        Bind Policy
                      </button>
                    </div>
                  )}

                  {policyStep === 'generating' && (
                    <div className="py-12 flex flex-col items-center justify-center text-center">
                      <Loader2 size={40} className="animate-spin text-blue-400 mb-4" />
                      <h3 className="text-xl font-bold text-white mb-2">Compiling Smart Contract</h3>
                      <p className="text-sm text-slate-400 font-mono">Minting dNFT Policy...</p>
                    </div>
                  )}

                  {policyStep === 'ready' && (
                    <div className="animate-in slide-in-from-bottom-4 duration-500 relative z-10 text-center">
                      <div className="w-16 h-16 glass-panel bg-emerald-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
                        <FileCheck className="text-emerald-400" size={32} />
                      </div>
                      <h2 className="text-2xl font-bold mb-6 text-white">Policy Bound Successfully</h2>
                      <button onClick={() => { setHasPolicy(true); setActiveTab('dashboard'); }} className="w-full sleek-btn text-white font-bold py-4 rounded-xl text-sm">
                        Enter Dashboard
                      </button>
                    </div>
                  )}
                </div>
              </div>
            )}

            {/* VIEW: ASSET DASHBOARD */}
            {activeTab === 'dashboard' && hasPolicy && (
              <div className="space-y-6 animate-in fade-in duration-500">
                <div className="glass-panel px-4 py-2 rounded-2xl flex items-center justify-between">
                  <div className="flex items-center gap-2">
                    {React.createElement(assetMeta[selectedAssetType].icon, { size: 18, className: "text-blue-400" })}
                    <span className="font-bold text-white">{assetMeta[selectedAssetType].label} Policy</span>
                  </div>
                  <span className="text-xs text-slate-400 font-mono">ORACLE SYNCED</span>
                </div>

                <div className="glass-panel-highlight rounded-3xl p-7 relative overflow-hidden">
                  <h3 className="text-blue-100/80 text-sm font-medium">Dynamic Premium</h3>
                  <div className="text-5xl font-bold font-mono text-white mt-2 drop-shadow-md">
                    {premium.dynamic} <span className="text-lg text-blue-200/80 font-sans tracking-normal">USD-B/mo</span>
                  </div>
                </div>

                <div className="grid grid-cols-2 gap-4">
                  <div className="glass-panel rounded-3xl p-5 flex flex-col items-center">
                    <div className="text-slate-400 text-xs mb-2">{assetMeta[selectedAssetType].metricLabel}</div>
                    <div className="text-3xl font-mono font-bold text-white">{assetMeta[selectedAssetType].getPrimaryVal(telemetry)}</div>
                  </div>
                  <div className="glass-panel rounded-3xl p-5 flex flex-col items-center">
                    <div className="text-slate-400 text-xs mb-2">{telemetry[selectedAssetType].metric1}</div>
                    <div className="text-2xl font-mono font-bold text-white">{telemetry[selectedAssetType].val1}</div>
                  </div>
                </div>

                <button onClick={handleParametricClaim} className="sleek-btn text-white font-bold py-4 w-full rounded-xl text-sm flex items-center justify-center gap-2">
                  <Activity size={18} /> Request Oracle Verification
                </button>
              </div>
            )}

            {/* VIEW: CAPITAL / BONDS */}
            {activeTab === 'capital' && (
              <div className="space-y-6 animate-in fade-in duration-500">
                <div className="glass-panel rounded-3xl p-6 relative overflow-hidden">
                  <div className="flex items-center gap-3 mb-2">
                    <Wallet size={18} className="text-blue-300" />
                    <h3 className="text-slate-200 text-sm font-semibold">ePurse Balance</h3>
                  </div>
                  <div className="text-4xl font-mono font-bold text-white mb-4">
                    {balances.usdB.toLocaleString()} <span className="text-sm text-slate-400">USD-B</span>
                  </div>
                  <div className="flex gap-3">
                    <button onClick={() => setShowFiatRamp(true)} className="flex-1 glass-panel bg-white/10 text-white font-semibold py-3 rounded-xl text-sm">Deposit</button>
                    <button className="flex-1 glass-panel bg-white/5 text-white font-semibold py-3 rounded-xl text-sm">Withdraw</button>
                  </div>
                </div>

                <div className="grid grid-cols-1 gap-4">
                  <div className="glass-panel p-5 rounded-2xl flex justify-between items-center">
                    <div className="flex items-center gap-3">
                      <Car size={16} className="text-blue-400"/> 
                      <span className="font-bold text-white">Mobility Pool</span>
                    </div>
                    <button onClick={() => setStakingModal({ isOpen: true, pool: 'Mobility Risk Pool', apy: '8.5%' })} className="glass-panel bg-blue-500/20 text-blue-100 px-4 py-2 rounded-xl text-xs font-bold">8.5% APY</button>
                  </div>
                </div>
              </div>
            )}

          </>
        )}
      </main>

      {/* FIAT ON-RAMP MODAL */}
      {showFiatRamp && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center px-4">
          <div className="absolute inset-0 bg-black/60 backdrop-blur-sm" onClick={() => setShowFiatRamp(false)}></div>
          <div className="glass-panel bg-[#0b101e]/90 w-full max-w-sm rounded-3xl p-6 relative z-10 border border-white/10">
            <h3 className="text-xl font-bold text-white mb-4">Fund ePurse</h3>
            <input type="number" value={fiatAmount} onChange={(e) => setFiatAmount(e.target.value)} className="w-full glass-input rounded-xl px-4 py-3.5 text-white font-mono text-lg mb-4" />
            <button onClick={() => {
              setIsProcessing(true);
              setTimeout(() => {
                setBalances(prev => ({ ...prev, usdB: prev.usdB + Number(fiatAmount) }));
                setIsProcessing(false); setShowFiatRamp(false);
                showToast(`Funded ePurse.`);
              }, 1500);
            }} className="w-full sleek-btn text-white font-bold py-4 rounded-xl text-sm disabled:opacity-50">
              {isProcessing ? 'Processing...' : `Pay ${fiatAmount} USD`}
            </button>
          </div>
        </div>
      )}

      {/* GLOBAL BOTTOM NAVIGATION */}
      {!isAdminMode && (
        <div className="fixed bottom-0 w-full z-50">
          <div className="glass-panel bg-[#0b101e]/60 border-b-0 border-x-0 border-t border-white/10 rounded-t-3xl shadow-[0_-10px_40px_rgba(0,0,0,0.3)]">
            <div className={`mx-auto flex justify-between px-2 py-3 transition-all duration-500 ${isMobileView ? 'max-w-md' : 'max-w-6xl'}`}>
              <button onClick={() => setActiveTab('onboarding')} className={`flex flex-1 flex-col items-center p-2 rounded-2xl transition-all ${activeTab === 'onboarding' || activeTab === 'mint' || activeTab === 'dashboard' ? 'text-white glass-panel bg-white/10' : 'text-slate-500'}`}>
                <ShieldCheck size={20} className="mb-1" />
                <span className="text-[9px] font-bold">Assets</span>
              </button>
              <button onClick={() => setActiveTab('capital')} className={`flex flex-1 flex-col items-center p-2 rounded-2xl transition-all ${activeTab === 'capital' ? 'text-white glass-panel bg-white/10' : 'text-slate-500'}`}>
                <Landmark size={20} className="mb-1" />
                <span className="text-[9px] font-bold">Capital</span>
              </button>
              <button onClick={() => setActiveTab('registry')} className={`flex flex-1 flex-col items-center p-2 rounded-2xl transition-all ${activeTab === 'registry' ? 'text-white glass-panel bg-white/10' : 'text-slate-500'}`}>
                <UserRound size={20} className="mb-1" />
                <span className="text-[9px] font-bold">Identity</span>
              </button>
            </div>
          </div>
        </div>
      )}
      
    </div>
  );
}
