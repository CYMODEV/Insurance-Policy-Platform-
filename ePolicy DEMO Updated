  return (
    <div className="fixed top-24 left-1/2 -translate-x-1/2 z-[200] w-11/12 max-w-sm">
      <div className="glass-panel-highlight bg-blue-900/90 border border-blue-400/50 p-4 rounded-xl flex items-start gap-3 shadow-2xl animate-in slide-in-from-top-4">
